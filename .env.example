# Flask Workshop Assistant Configuration
# Copy this file to .env and fill in your values

# Groq API Key (get from: https://console.groq.com)
# Free tier: 14,400 requests/day (more than enough for workshops)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Admin secret for instructor dashboard
ADMIN_SECRET=workshop2026

# Debug mode (set to False in production)
DEBUG=True
